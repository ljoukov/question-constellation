# Local Vite access to the analytics D1 database.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
ANALYTICS_DB_DATABASE_ID=d989edc1-26d8-4bd6-83f1-97b09c4d50a2

# Optional in local development; required as a Worker secret in production.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Optional alternative when the Worker is protected by Cloudflare Access.
ADMIN_ALLOWED_EMAILS=

# ChatGPT subscription proxy used for the AI overview.
CHATGPT_CODEX_PROXY_URL=
CHATGPT_CODEX_PROXY_API_KEY=
CHATGPT_RESPONSES_WEBSOCKET_MODE=off
