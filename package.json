{
	"name": "question-constellation",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"dev:server": "scripts/dev-server.sh start",
		"clean:adapter": "rm -rf .svelte-kit/cloudflare .svelte-kit/cloudflare-tmp .svelte-kit/output",
		"build": "npm run gen && vite build",
		"download:aqa-separate-science": "node scripts/download-aqa-separate-science.mjs",
		"extract:aqa-separate-science:batch": "node scripts/extract-aqa-separate-science-batch.mjs",
		"audit:extracted-data": "node scripts/audit-extracted-question-data.mjs",
		"audit:current-exported-data": "node scripts/audit-extracted-question-data.mjs --input-root=data/vision-extracted --recursive --output=tmp/current-exported-data-audit.json",
		"build:import-ready-extracted-subset": "node scripts/build-import-ready-extracted-subset.mjs",
		"build:existing-chain-context": "node scripts/build-existing-chain-context.mjs",
		"reconcile:answer-chains": "node scripts/reconcile-answer-chains.mjs",
		"prepare:import-ready-extraction": "node scripts/prepare-import-ready-extraction.mjs",
		"eval:question-solvability": "node scripts/evaluate-question-solvability.mjs",
		"summarize:llm-extraction-logs": "node scripts/summarize-llm-extraction-logs.mjs",
		"extract:physics-vision": "node scripts/extract-paper-llm.mjs --preset=aqa-physics",
		"extract:aqa-separate-science": "node scripts/extract-paper-llm.mjs --preset=aqa-separate-science",
		"extract:paper-llm": "node scripts/extract-paper-llm.mjs",
		"extract:production": "node scripts/run-production-extraction-pipeline.mjs",
		"import:chained": "node scripts/import-chained-questions.mjs",
		"import:vision": "node scripts/import-physics-vision.mjs",
		"import:physics-vision": "node scripts/import-physics-vision.mjs",
		"import:aqa-separate-science": "node scripts/import-physics-vision.mjs --input-root=data/vision-extracted/aqa-separate-science-higher --recursive",
		"audit:answer-chain-specificity": "node scripts/audit-answer-chain-specificity.mjs",
		"repair:extracted-data": "node scripts/repair-extracted-question-data.mjs",
		"repair:answer-chain-specificity": "node scripts/repair-answer-chain-specificity.mjs",
		"repair:extraction-response-assets": "node scripts/repair-extraction-response-assets.mjs",
		"backfill:model-answers": "node scripts/backfill-experiment-model-answers.mjs",
		"repair:experiment-grading": "node scripts/repair-experiment-grading-evidence.mjs",
		"upload:r2-images": "node scripts/upload-r2-images.mjs",
		"deploy": "wrangler deploy",
		"preview": "wrangler dev .svelte-kit/cloudflare/_worker.js --port 4173",
		"prepare": "svelte-kit sync || echo ''",
		"check": "npm run gen && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:grading:integration": "node scripts/test-grading-integration.mjs",
		"test:chain-golden": "node scripts/test-answer-chain-golden.mjs",
		"test:extraction-pipeline": "node scripts/test-extraction-pipeline.mjs",
		"eval:extraction-pipeline-llm": "node scripts/eval-extraction-pipeline-llm.mjs --run-llm",
		"test:unit": "vitest",
		"test": "vitest --run",
		"gen": "npm run clean:adapter && wrangler types --env-file .env.example && prettier --write worker-configuration.d.ts"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-cloudflare": "^7.2.9",
		"@sveltejs/kit": "^2.66.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/node": "^24",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.56.3",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.0.16",
		"vitest": "^4.1.3",
		"wrangler": "^4.81.0"
	},
	"dependencies": {
		"@ljoukov/llm": "7.0.23",
		"@lucide/svelte": "^1.16.0",
		"jose": "^6.2.3",
		"katex": "^0.16.27",
		"marked": "^17.0.1",
		"zod": "^4.4.3"
	}
}
