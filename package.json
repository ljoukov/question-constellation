{
	"name": "question-constellation",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"dev:server": "scripts/dev-server.sh start",
		"clean:adapter": "rm -rf .svelte-kit/cloudflare .svelte-kit/cloudflare-tmp .svelte-kit/output",
		"build": "pnpm run gen && vite build",
		"extract:aqa": "node scripts/extract-aqa-data.mjs",
		"upload:r2-images": "node scripts/upload-r2-images.mjs",
		"deploy": "wrangler deploy",
		"preview": "wrangler dev .svelte-kit/cloudflare/_worker.js --port 4173",
		"prepare": "svelte-kit sync || echo ''",
		"check": "pnpm run gen && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "pnpm run test:unit -- --run",
		"gen": "pnpm run clean:adapter && wrangler types --env-file .env.example && prettier --write worker-configuration.d.ts"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-cloudflare": "^7.2.9",
		"@sveltejs/kit": "^2.66.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/node": "^24",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.56.3",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.0.16",
		"vitest": "^4.1.3",
		"wrangler": "^4.81.0"
	},
	"dependencies": {
		"@lucide/svelte": "^1.16.0"
	}
}
